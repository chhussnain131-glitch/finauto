# Copy this file to .env and fill in your real Supabase credentials.
# Find these in your Supabase dashboard: Project Settings -> API

# Project URL, e.g. https://abcdefghij.supabase.co
SUPABASE_URL=https://your-project-ref.supabase.co

# IMPORTANT: use the SERVICE ROLE key (not the anon/public key).
# This key has full table access and must only live on the server (Flask),
# never in the browser. Keep .env out of git.
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Optional: set to 1 to enable Flask debug mode for local development
FLASK_DEBUG=1
